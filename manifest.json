{
  "manifest_version": 3,
  "name": "Visa Appointment Bot Pro1",
  "version": "2.0",
  "permissions": ["storage", "activeTab", "tabs", "alarms"],
  "host_permissions": ["https://ais.usvisa-info.com/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": ["https://ais.usvisa-info.com/en-ca/*"],
      "js": ["content.js"]
    }
  ]
}